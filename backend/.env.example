# --- Обязательно заполнить ---
# Токен бота от @BotFather — используется и для валидации Telegram initData
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Секрет для подписи JWT (длинная случайная строка): openssl rand -hex 32
JWT_SECRET=change-me-please-32-bytes-min

# --- Инфраструктура (для локали дефолты из docker-compose) ---
DATABASE_URL=postgresql+asyncpg://psy:psy@localhost:5432/psy
REDIS_URL=redis://localhost:6379/0

# --- Прочее ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30
# Разрешённые origin'ы фронтенда (через запятую)
CORS_ORIGINS=http://localhost:3000
# Макс. возраст Telegram initData в секундах (защита от replay)
INITDATA_MAX_AGE_SECONDS=86400
