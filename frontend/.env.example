# --- Обязательно ---
# Токен бота от @BotFather (валидация Telegram initData)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Секрет для подписи JWT: openssl rand -hex 32
JWT_SECRET=change-me-please-32-bytes-min
# Строка подключения к PostgreSQL
DATABASE_URL=postgresql://psy:psy@localhost:5432/psy

# --- Прочее ---
# Макс. возраст Telegram initData в секундах
INITDATA_MAX_AGE_SECONDS=86400
# За сколько минут до сессии слать напоминание (бот)
REMINDER_LEAD_MIN=60

# --- ЮKassa (магазин на ИП; заполнить после модерации) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Секрет для проверки подписи вебхука (если используется) — иначе сверяем по IP/факту
YOOKASSA_WEBHOOK_SECRET=
# Цена подписки Pro в рублях
SUBSCRIPTION_PRICE_RUB=990
# Базовый публичный URL приложения (для return_url ЮKassa)
NEXT_PUBLIC_APP_URL=http://localhost:3000
